# Site URL
# Used for sitemap and robots metadata. Falls back to Vercel URLs or http://localhost:3000.
SITE_URL="http://localhost:3000"

# Vercel-provided URLs
# These are normally set by Vercel and are optional for local development.
VERCEL_PROJECT_PRODUCTION_URL=""
VERCEL_URL=""

# Discord / Lanyard
# NEXT_PUBLIC_DISCORD_USER_ID is exposed to the browser and should generally match DISCORD_USER_ID.
DISCORD_USER_ID=""
NEXT_PUBLIC_DISCORD_USER_ID=""

# Spotify
# Leave blank to use mock / empty Spotify data.
SPOTIFY_CLIENT_ID=""
SPOTIFY_SECRET_ID=""
SPOTIFY_REFRESH_TOKEN=""

# Steam
# Leave blank to use mock Steam data.
STEAM_API_KEY=""
STEAM_ID=""

# TMDB
# Leave blank to use mock TMDB data.
TMDB_API_READ_ACCESS_TOKEN=""
TMDB_ACCOUNT_ID=""
